# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" for local dev, and set the same
# variables in your Vercel project (Settings → Environment Variables).
# Everything is OPTIONAL for local dev — the app falls back to JSON
# files and URL-paste image fields when these are not set.
# ─────────────────────────────────────────────────────────────

# Neon Postgres connection string (required for data to persist on Vercel).
# Create a free DB at https://neon.tech → copy the "pooled" connection string.
# Without it, data is read/written to the /data JSON files (local dev only).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Vercel Blob token (required for image UPLOADS from the admin panel).
# Vercel Dashboard → Storage → Blob → create store → copy the token.
# Without it, you can still paste image URLs in the admin instead of uploading.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"
